
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user identity and role management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "parent", "tutor", "admin"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "StudentProfile": {
      "title": "Student Profile",
      "description": "Academic records and progress tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "parentId": { "type": "string" },
        "grade": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "targetExam": { "type": "string" },
        "weakSubjects": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "CRM inquiry for admission or home tuition.",
      "type": "object",
      "properties": {
        "parentName": { "type": "string" },
        "studentName": { "type": "string" },
        "phone": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "locality": { "type": "string" },
        "type": { "type": "string", "enum": ["admission", "home_tuition", "tutor_app"] },
        "status": { "type": "string", "enum": ["new", "contacted", "demo_scheduled", "converted"] },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User directory."
    },
    "/students/{studentId}": {
      "schema": "StudentProfile",
      "description": "Academic profiles."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "CRM database."
    }
  }
}
