{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user identity and role management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "parent", "tutor", "admin"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "StudentProfile": {
      "title": "Student Profile",
      "description": "Academic records and progress tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "parentId": { "type": "string" },
        "grade": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "targetExam": { "type": "string" },
        "weakSubjects": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated"] }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "CRM inquiry for admission or home tuition.",
      "type": "object",
      "properties": {
        "parentName": { "type": "string" },
        "studentName": { "type": "string" },
        "phone": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "locality": { "type": "string" },
        "type": { "type": "string", "enum": ["admission", "home_tuition", "general_enquiry"] },
        "status": { "type": "string", "enum": ["new", "contacted", "demo_scheduled", "demo_completed", "converted", "lost"] },
        "createdAt": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "HealthCheck": {
      "title": "Health Check",
      "description": "Stored AI Diagnostic reports for students.",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "gradeLevel": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "totalScore": { "type": "number" },
        "reportSummary": { "type": "string" },
        "createdAt": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Attendance": {
      "title": "Attendance Record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "subject": { "type": "string" }
      }
    },
    "TestResult": {
      "title": "Test Result",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "testDate": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "rank": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "General user directory."
    },
    "/students/{studentId}": {
      "schema": "StudentProfile",
      "description": "In-depth academic records."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Unified CRM pipeline for admissions and tuition."
    },
    "/health_checks/{checkId}": {
      "schema": "HealthCheck",
      "description": "Captured diagnostic data for lead nurturing."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs."
    },
    "/test_results/{resultId}": {
      "schema": "TestResult",
      "description": "Scholar exam results."
    }
  }
}
