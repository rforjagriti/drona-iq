
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core user identity and role management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "parent", "tutor", "admin"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "StudentProfile": {
      "title": "Student Profile",
      "description": "Academic records and progress tracking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "parentId": { "type": "string" },
        "grade": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "targetExam": { "type": "string" },
        "weakSubjects": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "suspended", "graduated"] }
      }
    },
    "Class": {
      "title": "Running Class",
      "description": "Information about currently active or upcoming batches.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string", "enum": ["center", "online", "home_tuition"] },
        "timing": { "type": "string" },
        "status": { "type": "string", "enum": ["enrolling", "full", "upcoming"] },
        "mentor": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "CRM inquiry for admission or home tuition.",
      "type": "object",
      "properties": {
        "parentName": { "type": "string" },
        "studentName": { "type": "string" },
        "phone": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "locality": { "type": "string" },
        "type": { "type": "string", "enum": ["admission", "home_tuition", "general_enquiry"] },
        "status": { "type": "string", "enum": ["new", "contacted", "demo_scheduled", "demo_completed", "converted", "lost"] },
        "createdAt": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "General user directory."
    },
    "/students/{studentId}": {
      "schema": "StudentProfile",
      "description": "In-depth academic records."
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Directory of active and upcoming batches."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Unified CRM pipeline for admissions and tuition."
    }
  }
}
